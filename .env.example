# =============================================================
# USER PROFILE SERVICE â€” STARTUP ORDER
# =============================================================
# Services must be started in this order in development:
#
#   1. cd clublaze-club-service && docker-compose -f docker-compose.dev.yml up
#      (starts MongoDB, Redis, Zookeeper, Kafka, and club-service)
#
#   2. cd clublaze-auth-service && docker-compose -f docker-compose.dev.yml up
#      (starts MongoDB and auth-service, connects to club-service Kafka)
#
#   3. cd clublaze-user-profile-service && docker-compose -f docker-compose.dev.yml up
#      (starts MongoDB, Redis, and profile-service, connects to club-service Kafka)
#
#   4. cd clublaze-frontend && npm run dev
#
# Kafka topic flow:
#   auth-service  â†’  user-events          â†’  profile-service (create/block profile)
#   auth-service  â†’  user-events          â†’  club-service    (revoke memberships on block)
#   club-service  â†’  role.assigned        â†’  profile-service (stats + badges)
#   club-service  â†’  event.approved       â†’  profile-service (stats + badges)
#   club-service  â†’  membership.reviewed  â†’  profile-service (stats + badges)
# =============================================================
# â”€â”€ Server â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
PORT=8003
NODE_ENV=development
FRONTEND_BASE_URL=http://localhost:5173

# â”€â”€ MongoDB â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
MONGODB_URI=mongodb://localhost:27017/unihub_profile

# â”€â”€ Redis â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
REDIS_URL=redis://localhost:6379

# â”€â”€ Kafka â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Must point to club-service's shared Kafka external port.
# Both auth-service and profile-service connect to this same broker.
# Dev: localhost:9093
# Production: your managed Kafka URL (AWS MSK / Confluent Cloud)
# Start club-service's docker-compose before profile-service.
KAFKA_BROKERS=localhost:9093
KAFKA_CLIENT_ID=user-profile-service
KAFKA_GROUP_ID=user-profile-service-group

# â”€â”€ JWT â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Must equal JWT_ACCESS_SECRET from auth-service .env exactly.
# Auth-service uses the name JWT_ACCESS_SECRET to sign tokens.
# Club-service and profile-service use JWT_SECRET to verify them.
# They are the same secret value, just named differently per service.
JWT_SECRET=your_jwt_secret_here_must_match_auth_service

# â”€â”€ Internal service communication â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Must be identical to INTERNAL_SERVICE_SECRET in auth-service and club-service .env
INTERNAL_SERVICE_SECRET=your_internal_service_secret_here

# â”€â”€ Other service URLs â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
AUTH_SERVICE_URL=http://localhost:8001
CLUB_SERVICE_URL=http://localhost:8002
# Leaderboard service does not exist yet â€” profile-service handles this gracefully
LEADERBOARD_SERVICE_URL=http://localhost:8004

# â”€â”€ AWS S3 (leave empty in development â€” placeholder URLs will be used instead) â”€â”€
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=unihub-uploads
AWS_S3_BASE_URL=

# â”€â”€ Upload limits â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
MAX_AVATAR_SIZE_MB=5
MAX_COVER_SIZE_MB=10
