JWT_SECRET=9b5e2f8cd1e4b73f47cdd61a8f1e4cdb84ed5c44c916529c0edc8dc8a4c356a1

# MUST match across ALL services (auth, club, profile)
INTERNAL_SERVICE_SECRET=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2

